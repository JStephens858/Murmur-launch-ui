# Auth0 — copy to .env.local and fill in from the Auth0 dashboard
# (Applications → your Regular Web Application for the website).
# AUTH0_SECRET is for session-cookie encryption; generate with:
#   openssl rand -hex 32

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=generate-with-openssl-rand-hex-32
APP_BASE_URL=http://localhost:3000

# MurmurMD GraphQL API (Apollo server)
MURMUR_API_SERVER=http://localhost:4000/api
# Optional: Auth0 API identifier, if the GraphQL server requires a JWT
# access token minted for a specific audience
# AUTH0_AUDIENCE=
